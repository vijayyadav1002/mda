DATABASE_URL=postgresql://postgres:postgres@localhost:5432/mda
JWT_SECRET=your-secret-key-change-this-in-production
PORT=4000
HOST=0.0.0.0
MEDIA_LIBRARY_PATH=/path/to/your/media/library
THUMBNAIL_CACHE_PATH=./cache/thumbnails
LOW_STORAGE_MODE=true

# Thumbnail generation strategy (Phase 3: On-demand optimization)
# Set to "true" for on-demand thumbnail generation (recommended for Raspberry Pi)
# When enabled: thumbnails are generated only when user scrolls to them
# When disabled: thumbnails are queued immediately when folder is indexed
THUMBNAILS_ON_DEMAND=false

# Output tuning
THUMBNAIL_SIZE=240
THUMBNAIL_QUALITY=65
PREVIEW_MAX_DIMENSION=1280
PREVIEW_QUALITY=70

# Cleanup schedule
CACHE_CLEANUP_INTERVAL_MINUTES=30

# Age limits
THUMBNAIL_CACHE_MAX_AGE_DAYS=30
PREVIEW_CACHE_MAX_AGE_DAYS=7
HLS_CACHE_MAX_AGE_HOURS=24
TRANSCODED_CACHE_MAX_AGE_HOURS=2

# Size limits
THUMBNAIL_CACHE_MAX_MB=250
PREVIEW_CACHE_MAX_MB=150
HLS_CACHE_MAX_MB=500
TRANSCODED_CACHE_MAX_MB=250
